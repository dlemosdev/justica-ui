{
  "name": "justica-ui-workspace",
  "version": "11.0.0",
  "scripts": {
    "ng": "ng",
    "prepare": "husky install",
    "start": "ng serve",
    "start:dev": "node ./scripts/start-dev.mjs",
    "start:demo": "ng serve justica-ui-demo --proxy-config proxy.conf.json",
    "start:demo:dev": "ng serve justica-ui-demo --proxy-config proxy.dev.config.json",
    "build": "ng build",
    "build:justica-ui": "ng build justica-ui --configuration production",
    "watch:justica-ui": "ng build justica-ui --watch",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint --edit",
    "verdaccio:up": "docker compose up -d verdaccio",
    "verdaccio:down": "docker compose down",
    "verdaccio:logs": "docker compose logs -f verdaccio",
    "pack:ui": "cd dist/justica-ui && npm pack",
    "publish:local": "npm run build:justica-ui && npm publish ./dist/justica-ui --no-update-notifier --registry http://localhost:4873",
    "publish:snapshot": "npm run build:justica-ui && npm publish ./dist/justica-ui --no-update-notifier --registry=https://nexus.stj.jus.br/repository/npm-snapshot/",
    "publish:release": "npm run build:justica-ui && npm publish ./dist/justica-ui --no-update-notifier --registry=https://nexus.stj.jus.br/repository/npm-release/",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~11.1.1",
    "@angular/common": "~11.1.1",
    "@angular/compiler": "~11.1.1",
    "@angular/core": "~11.1.1",
    "@angular/forms": "~11.1.1",
    "@angular/platform-browser": "~11.1.1",
    "@angular/platform-browser-dynamic": "~11.1.1",
    "@angular/router": "~11.1.1",
    "@fortawesome/fontawesome-free": "^6.5.2",
    "@justica/core": "^11.0.21",
    "rxjs": "~6.6.0",
    "tslib": "^2.0.0",
    "zone.js": "~0.11.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.1101.2",
    "@angular-eslint/builder": "^4.3.0",
    "@angular-eslint/eslint-plugin": "^4.3.0",
    "@angular-eslint/eslint-plugin-template": "^4.3.0",
    "@angular-eslint/schematics": "^4.3.0",
    "@angular-eslint/template-parser": "^4.3.0",
    "@angular/cli": "~11.1.2",
    "@angular/compiler-cli": "~11.1.1",
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^17.8.1",
    "@types/jasmine": "~3.6.0",
    "@types/node": "^12.11.1",
    "@typescript-eslint/eslint-plugin": "^4.16.1",
    "@typescript-eslint/parser": "^4.16.1",
    "eslint": "^7.6.0",
    "husky": "^8.0.3",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~5.2.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "lint-staged": "^12.5.0",
    "ng-packagr": "^11.0.0",
    "prettier": "^2.8.8",
    "protractor": "~7.0.0",
    "ts-node": "~8.3.0",
    "typescript": "~4.1.2"
  }
}
