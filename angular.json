{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "justica-ui": {
      "projectType": "library",
      "root": "projects/justica-ui",
      "sourceRoot": "projects/justica-ui/src",
      "prefix": "justica",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "tsConfig": "projects/justica-ui/tsconfig.lib.json",
            "project": "projects/justica-ui/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/justica-ui/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/justica-ui/src/test.ts",
            "tsConfig": "projects/justica-ui/tsconfig.spec.json",
            "karmaConfig": "projects/justica-ui/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/justica-ui/**/*.ts",
              "projects/justica-ui/**/*.html"
            ]
          }
        }
      }
    },
    "justica-ui-demo": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/justica-ui-demo",
      "sourceRoot": "projects/justica-ui-demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/justica-ui-demo",
            "index": "projects/justica-ui-demo/src/index.html",
            "main": "projects/justica-ui-demo/src/main.ts",
            "polyfills": "projects/justica-ui-demo/src/polyfills.ts",
            "tsConfig": "projects/justica-ui-demo/tsconfig.app.json",
            "aot": true,
            "assets": [
              {
                "glob": "favicon.ico",
                "input": "projects/justica-ui/src/lib/assets",
                "output": "/"
              },
              "projects/justica-ui-demo/src/assets"
            ],
            "styles": [
              "dist/justica-ui/src/lib/styles/justica-ui.css",
              "projects/justica-ui-demo/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/justica-ui-demo/src/environments/environment.ts",
                  "with": "projects/justica-ui-demo/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "justica-ui-demo:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "justica-ui-demo:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "justica-ui-demo:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/justica-ui-demo/src/test.ts",
            "polyfills": "projects/justica-ui-demo/src/polyfills.ts",
            "tsConfig": "projects/justica-ui-demo/tsconfig.spec.json",
            "karmaConfig": "projects/justica-ui-demo/karma.conf.js",
            "assets": [
              {
                "glob": "favicon.ico",
                "input": "projects/justica-ui/src/lib/assets",
                "output": "/"
              },
              "projects/justica-ui-demo/src/assets"
            ],
            "styles": [
              "node_modules/font-awesome/css/font-awesome.min.css",
              "dist/justica-ui/src/lib/styles/justica-ui.css",
              "projects/justica-ui-demo/src/styles.css"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/justica-ui-demo/**/*.ts",
              "projects/justica-ui-demo/**/*.html"
            ]
          }
        },
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "projects/justica-ui-demo/e2e/protractor.conf.js",
            "devServerTarget": "justica-ui-demo:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "justica-ui-demo:serve:production"
            }
          }
        }
      }
    }
  },
  "defaultProject": "justica-ui"
}
